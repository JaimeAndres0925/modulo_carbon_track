<?xml version="1.0" encoding="utf-8"?>
<!-- Secuenciar los ids en odoo-->
<odoo>
    <data noupdate="1">
        <record id="seq_carbon_track_registro" model="ir.sequence">
            <field name="name">Secuencia de Registros CO2</field>
            <field name="code">carbon.track.registro.secuencia</field>
            <field name="prefix">CO2/%(year)s/</field>
            <field name="padding">4</field>
            <field name="company_id" eval="False"/>
        </record>

        <record id="seq_carbon_track_actividad" model="ir.sequence">
            <field name="name">Secuencia de Actividades</field>
            <field name="code">carbon.track.actividad</field>
            <field name="prefix">ACT-</field>
            <field name="padding">3</field>
            <field name="company_id" eval="False"/>
        </record>

        <record id="seq_carbon_track_compensacion" model="ir.sequence">
            <field name="name">Secuencia de Compensaciones</field>
            <field name="code">carbon.track.compensacion</field>
            <field name="prefix">COMP/%(year)s/</field>
            <field name="padding">4</field>
            <field name="company_id" eval="False"/>
        </record>
        <record id="seq_carbon_track_cae" model="ir.sequence">
            <field name="name">Secuencia CAE</field>
            <field name="code">carbon.track.cae</field>
            <field name="prefix">CAE/%(year)s/</field>
            <field name="padding">3</field>
            <field name="company_id" eval="False"/>
        </record>
    </data>
</odoo>

