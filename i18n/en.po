#. module: modulo_carbon_track
msgid ""
"<div style=\"margin: 0px; padding: 0px; font-family: Arial, Helvetica, sans-serif;\">\n"
"                <p style=\"margin: 0px; padding: 0px; font-size: 13px;\">\n"
"                    Hola,<br/><br/>\n"
"                    A continuación, se detalla el resumen del <strong>Informe de Huella de Carbono</strong> correspondiente al periodo <strong><t t-out=\"object.name\"/></strong>.\n"
"                    <br/><br/>\n"
"                    <strong>Resumen del Periodo:</strong>\n"
"                    </p><ul>\n"
"                        <li>Presupuesto Máximo: <t t-out=\"object.presupuesto_co2e\"/> kg</li>\n"
"                        <li>Total Consumido: <t t-out=\"object.total_co2e_consumido\"/> kg</li>\n"
"                        <li>Total Compensado: <t t-out=\"object.total_co2e_compensado\"/> kg</li>\n"
"                        <li>Huella Neta Final: <strong><t t-out=\"object.huella_neta\"/> kg</strong></li>\n"
"                    </ul>\n"
"                    <br/>\n"
"                    <t t-if=\"object.es_net_zero\">\n"
"                        <span style=\"color: #28a745; font-weight: bold; font-size: 15px;\">\n"
"                            Hemos alcanzado el objetivo Net Zero en este periodo.\n"
"                        </span><br/><br/>\n"
"                    </t>\n"
"                    Gracias,<br/>\n"
"                    Departamento de Sostenibilidad\n"
"                \n"
"            </div>\n"
"        "
msgstr ""
"<div style=\"margin: 0px; padding: 0px; font-family: Arial, Helvetica, sans-serif;\">\n"
"                <p style=\"margin: 0px; padding: 0px; font-size: 13px;\">\n"
"                    Hello,<br/><br/>\n"
"                    Below is the summary of the <strong>Carbon Footprint Report</strong> for the period <strong><t t-out=\"object.name\"/></strong>.\n"
"                    <br/><br/>\n"
"                    <strong>Period Summary:</strong>\n"
"                    </p><ul>\n"
"                        <li>Maximum Budget: <t t-out=\"object.presupuesto_co2e\"/> kg</li>\n"
"                        <li>Total Consumed: <t t-out=\"object.total_co2e_consumido\"/> kg</li>\n"
"                        <li>Total Offset: <t t-out=\"object.total_co2e_compensado\"/> kg</li>\n"
"                        <li>Final Net Footprint: <strong><t t-out=\"object.huella_neta\"/> kg</strong></li>\n"
"                    </ul>\n"
"                    <br/>\n"
"                    <t t-if=\"object.es_net_zero\">\n"
"                        <span style=\"color: #28a745; font-weight: bold; font-size: 15px;\">\n"
"                            We have reached the Net Zero target for this period.\n"
"                        </span><br/><br/>\n"
"                    </t>\n"
"                    Thank you,<br/>\n"
"                    Sustainability Department\n"
"                \n"
"            </div>\n"
"        "

#. module: modulo_carbon_track
msgid ""
"<i class=\"fa fa-exclamation-triangle\"/> <strong>¡Atención! Política de Sostenibilidad:</strong> \n"
"                    Este informe de gastos contiene partidas que superan los 150 kg de CO2e. \n"
"                    Requiere justificación y aprobación excepcional por parte de Sostenibilidad."
msgstr ""
"<i class=\"fa fa-exclamation-triangle\"/> <strong>Attention! Sustainability Policy:</strong> \n"
"                    This expense report contains items exceeding 150 kg of CO2e. \n"
"                    It requires justification and exceptional approval from the Sustainability team."

#. module: modulo_carbon_track
msgid ""
"<i class=\"fa fa-external-link\"/> \n"
"                        <strong>Nota para el usuario:</strong> Para una comprensión profunda, consulte la documentación oficial en el enlace superior."
msgstr ""
"<i class=\"fa fa-external-link\"/> \n"
"                        <strong>Note for the user:</strong> For a deeper understanding, please consult the official documentation at the link above."

#. module: modulo_carbon_track
msgid ""
"<i class=\"fa fa-info-circle\"/> <strong>Información de Auditoría:</strong> "
"Al sincronizar, Odoo descargará los factores de emisión actualizados del GHG"
" Protocol y de la EPA. Estos factores se bloquearán para evitar "
"manipulaciones manuales por parte de los usuarios."
msgstr ""
"<i class=\"fa fa-info-circle\"/> <strong>Audit Information:</strong> "
"When syncing, Odoo will download updated emission factors from the GHG "
"Protocol and the EPA. These factors will be locked to prevent "
"manual manipulation by users."

#. module: modulo_carbon_track
msgid ""
"<i class=\"fa fa-leaf\"/> <strong>Impacto Ambiental Estimado:</strong> \n"
"                    Este gasto generará"
msgstr ""
"<i class=\"fa fa-leaf\"/> <strong>Estimated Environmental Impact:</strong> \n"
"                    This expense will generate"

