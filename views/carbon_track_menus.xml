<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Plantilla de Correo Automática -->
    <record id="email_template_periodo" model="mail.template">
        <field name="name">Envío de Informe de Sostenibilidad</field>
        <field name="model_id" ref="modulo_carbon_track.model_carbon_track_periodo"/>
        <field name="subject">Informe de Huella de Carbono: {{ object.name }}</field>
        <field name="body_html" type="html">
            <div style="margin: 0px; padding: 0px; font-family: Arial, Helvetica, sans-serif;">
                <p style="margin: 0px; padding: 0px; font-size: 13px;">
                    Hola,<br/><br/>
                    A continuación, se detalla el resumen del <strong>Informe de Huella de Carbono</strong> correspondiente al periodo <strong><t t-out="object.name"/></strong>.
                    <br/><br/>
                    <strong>Resumen del Periodo:</strong>
                    <ul>
                        <li>Presupuesto Máximo: <t t-out="object.presupuesto_co2e"/> kg</li>
                        <li>Total Consumido: <t t-out="object.total_co2e_consumido"/> kg</li>
                        <li>Total Compensado: <t t-out="object.total_co2e_compensado"/> kg</li>
                        <li>Huella Neta Final: <strong><t t-out="object.huella_neta"/> kg</strong></li>
                    </ul>
                    <br/>
                    <t t-if="object.es_net_zero">
                        <span style="color: #28a745; font-weight: bold; font-size: 15px;">
                            Hemos alcanzado el objetivo Net Zero en este periodo.
                        </span><br/><br/>
                    </t>
                    Gracias,<br/>
                    Departamento de Sostenibilidad
                </p>
            </div>
        </field>
    </record>
    <record id="action_carbon_track_alcance" model="ir.actions.act_window">
        <field name="name">Alcances</field>
        <field name="res_model">carbon.track.alcance</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="action_carbon_track_periodo" model="ir.actions.act_window">
        <field name="name">Periodos</field>
        <field name="res_model">carbon.track.periodo</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="action_carbon_track_emision" model="ir.actions.act_window">
        <field name="name">Factores de Emisión</field>
        <field name="res_model">carbon.track.emision</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="action_carbon_track_actividad" model="ir.actions.act_window">
        <field name="name">Actividades</field>
        <field name="res_model">carbon.track.actividad</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="action_carbon_track_reporte" model="ir.actions.act_window">
        <field name="name">Informes de Emisiones</field>
        <field name="res_model">carbon.track.reporte</field>
        <field name="view_mode">list,form</field> 
    </record>

    <record id="action_carbon_track_fuente_externa" model="ir.actions.act_window">
        <field name="name">Fuentes Externas API</field>
        <field name="res_model">carbon.track.fuente.externa</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="action_carbon_track_registro" model="ir.actions.act_window">
        <field name="name">Registros de Consumo</field>
        <field name="res_model">carbon.track.registro</field>
        <field name="view_mode">list,form,graph</field> 
    </record>

    <record id="action_carbon_track_compensacion" model="ir.actions.act_window">
        <field name="name">Compensaciones</field>
        <field name="res_model">carbon.track.compensacion</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="view_carbon_track_registro_list" model="ir.ui.view">
        <field name="name">carbon.track.registro.list</field>
        <field name="model">carbon.track.registro</field>
        <field name="arch" type="xml">
            <list string="Registros de Consumo" decoration-info="valor_co2e &gt; 0">
                <field name="fecha"/>
                <field name="actividad_id"/>
                <field name="periodo_id"/>
                <field name="cantidad"/>
                <field name="unidad"/>
                <field name="valor_co2e" sum="Total CO2e Generado"/>
                <field name="nivel_impacto" 
                       widget="badge" 
                       decoration-success="nivel_impacto == 'bajo'" 
                       decoration-warning="nivel_impacto == 'medio'" 
                       decoration-danger="nivel_impacto == 'alto'"/>
            </list>
        </field>
    </record>

    <record id="view_carbon_track_registro_graph" model="ir.ui.view">
        <field name="name">carbon.track.registro.graph</field>
        <field name="model">carbon.track.registro</field>
        <field name="arch" type="xml">
            <graph string="Análisis de Emisiones" type="bar" sample="1">
                <field name="actividad_id"/> 
                <field name="valor_co2e" type="measure"/>
            </graph>
        </field>
    </record>

    <record id="view_carbon_track_actividad_form" model="ir.ui.view">
        <field name="name">carbon.track.actividad.form</field>
        <field name="model">carbon.track.actividad</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_registros" 
                                type="object" 
                                class="oe_stat_button" 
                                icon="fa-leaf">
                            <div class="o_stat_info">
                                <field name="registro_count" class="o_stat_value"/>
                                <span class="o_stat_text">Registros</span>
                                <span class="o_stat_text">
                                    <field name="total_co2e_acumulado" widget="float"/> kg
                                </span>
                            </div>
                        </button>
                    </div>
                    <group>
                        <field name="name"/>
                        <field name="alcance_id"/>
                        <field name="factor_emision_id"/>
                        <field name="unidad"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_carbon_track_periodo_list" model="ir.ui.view">
        <field name="name">carbon.track.periodo.list</field>
        <field name="model">carbon.track.periodo</field>
        <field name="arch" type="xml">
            <list string="Periodos">
                <field name="name"/>
                <field name="presupuesto_co2e"/>
                <field name="total_co2e_consumido"/>
                <field name="porcentaje_consumido" widget="progressbar"/>
            </list>
        </field>
    </record>

    <record id="view_carbon_track_periodo_form" model="ir.ui.view">
        <field name="name">carbon.track.periodo.form</field>
        <field name="model">carbon.track.periodo</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_send_email" 
                            string="Enviar Informe por Email" 
                            type="object" 
                            class="oe_highlight" 
                            icon="fa-envelope"/>
                </header>
                <sheet>
                    <widget name="web_ribbon" title="¡NET ZERO!" bg_color="text-bg-success" invisible="not es_net_zero"/>
                    <div class="oe_title">
                        <h1><field name="name" placeholder="Ej. Mayo 2026"/></h1>
                    </div>
                    <group>
                        <group string="Balance Ecológico">
                            <field name="total_co2e_consumido" decoration-danger="1"/>
                            <field name="total_co2e_compensado" decoration-success="1"/>
                            <field name="huella_neta" class="fw-bold fs-5"/>
                        </group>
                        <group string="Control de Presupuesto">
                            <field name="presupuesto_co2e"/>
                            <field name="porcentaje_consumido" widget="progressbar"/>
                            <field name="es_net_zero" invisible="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Proyectos de Compensación">
                            <field name="compensacion_ids">
                                <list editable="bottom">
                                    <field name="fecha"/>
                                    <field name="name"/>
                                    <field name="tipo"/>
                                    <field name="co2e_compensado" sum="Total"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_carbon_track_fuente_externa_form" model="ir.ui.view">
        <field name="name">carbon.track.fuente.externa.form</field>
        <field name="model">carbon.track.fuente.externa</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_test_connection" string="1. Probar Conexión" type="object" class="oe_highlight"/>
                    <button name="action_sync_factors" string="2. Sincronizar Catálogo" type="object" class="btn-success" invisible="estado != 'conectado'"/>
                    <field name="estado" widget="statusbar"/>
                </header>
                <sheet>
                    <widget name="web_ribbon" title="CONECTADO" bg_color="text-bg-success" invisible="estado != 'conectado'"/>
                    <div class="oe_title">
                        <h1><field name="name"/></h1>
                    </div>
                    <group>
                        <group string="Credenciales">
                            <field name="api_key" password="True" placeholder="Pega aquí tu token de Climatiq..."/>
                            <field name="base_url"/>
                        </group>
                        <group string="Información de Sincronización">
                            <field name="ultima_sincronizacion"/>
                        </group>
                    </group>
                    <div class="alert alert-info" role="alert" style="margin-top: 20px;">
                        <i class="fa fa-info-circle"></i> <strong>Información de Auditoría:</strong> Al sincronizar, Odoo descargará los factores de emisión actualizados del GHG Protocol y de la EPA. Estos factores se bloquearán para evitar manipulaciones manuales por parte de los usuarios.
                    </div>
                </sheet>
            </form>
        </field>
    </record>

    <menuitem id="menu_carbon_track_root" 
              name="Carbon Track" 
              web_icon="modulo_carbon_track,static/description/icon.png"/>

    <menuitem id="menu_carbon_track_operations" 
              name="Operaciones" 
              parent="menu_carbon_track_root" 
              sequence="10"/>

    <menuitem id="menu_carbon_track_reports" 
              name="Informes" 
              parent="menu_carbon_track_root" 
              sequence="20"/>

    <menuitem id="menu_carbon_track_config" 
              name="Configuración" 
              parent="menu_carbon_track_root" 
              sequence="100"/>

    <menuitem id="menu_carbon_track_registro" 
              name="Registros de Consumo" 
              parent="menu_carbon_track_operations" 
              action="action_carbon_track_registro" 
              sequence="10"/>

    <menuitem id="menu_carbon_track_actividad" 
              name="Actividades" 
              parent="menu_carbon_track_operations" 
              action="action_carbon_track_actividad" 
              sequence="20"/>

    <menuitem id="menu_carbon_track_compensacion" 
              name="Compensaciones" 
              parent="menu_carbon_track_operations" 
              action="action_carbon_track_compensacion" 
              sequence="30"/>

    <menuitem id="menu_carbon_track_reporte_list" 
              name="Resumen de Emisiones" 
              parent="menu_carbon_track_reports" 
              action="action_carbon_track_reporte" 
              sequence="10"/>

    <menuitem id="menu_carbon_track_alcance_config" 
              name="Alcances" 
              parent="menu_carbon_track_config" 
              action="action_carbon_track_alcance" 
              sequence="10"/>

    <menuitem id="menu_carbon_track_periodo_config" 
              name="Periodos" 
              parent="menu_carbon_track_config" 
              action="action_carbon_track_periodo" 
              sequence="20"/>

    <menuitem id="menu_carbon_track_emision_config" 
              name="Factores de Emisión" 
              parent="menu_carbon_track_config" 
              action="action_carbon_track_emision" 
              sequence="30"/>

    <menuitem id="menu_carbon_track_fuente_externa_config" 
              name="Fuentes Externas (API)" 
              parent="menu_carbon_track_config" 
              action="action_carbon_track_fuente_externa" 
              sequence="40"/>
</odoo>