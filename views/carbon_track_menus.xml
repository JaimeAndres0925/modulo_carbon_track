<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Plantilla de Correo Automática -->
    <record id="email_template_periodo" model="mail.template">
        <field name="name">Envío de Informe de Sostenibilidad</field>
        <field name="model_id" ref="modulo_carbon_track.model_carbon_track_periodo"/>
        <field name="subject">Informe de Huella de Carbono: {{ object.name }}</field>
        <field name="body_html" type="html">
            <div style="margin: 0px; padding: 0px; font-family: Arial, Helvetica, sans-serif;">
                <p style="margin: 0px; padding: 0px; font-size: 13px;">
                    Hola,<br/><br/>
                    A continuación, se detalla el resumen del <strong>Informe de Huella de Carbono</strong> correspondiente al periodo <strong><t t-out="object.name"/></strong>.
                    <br/><br/>
                    <strong>Resumen del Periodo:</strong>
                    <ul>
                        <li>Presupuesto Máximo: <t t-out="object.presupuesto_co2e"/> kg</li>
                        <li>Total Consumido: <t t-out="object.total_co2e_consumido"/> kg</li>
                        <li>Total Compensado: <t t-out="object.total_co2e_compensado"/> kg</li>
                        <li>Huella Neta Final: <strong><t t-out="object.huella_neta"/> kg</strong></li>
                    </ul>
                    <br/>
                    <t t-if="object.es_net_zero">
                        <span style="color: #28a745; font-weight: bold; font-size: 15px;">
                            Hemos alcanzado el objetivo Net Zero en este periodo.
                        </span><br/><br/>
                    </t>
                    Gracias,<br/>
                    Departamento de Sostenibilidad
                </p>
            </div>
        </field>
    </record>


    <!-- Plantilla para las tarjetas del Alcance -->
    <record id="view_carbon_track_alcance_kanban" model="ir.ui.view">
        <field name="name">carbon.track.alcance.kanban</field>
        <field name="model">carbon.track.alcance</field>
        <field name="arch" type="xml">
            <kanban create="false" can_order="false"> <field name="id"/>
                <field name="name"/>
                <field name="descripcion"/>
                <field name="imagen"/>
                <templates>
                    <t t-name="kanban-box">
                        <div class="oe_kanban_global_click d-flex flex-column p-3 border-start border-4 border-info shadow-sm">
                            <div class="d-flex align-items-center mb-2">
                                <div class="me-3">
                                    <field name="imagen" widget="image" options="{'preview_image': 'imagen', 'size': [60, 60]}"/>
                                </div>
                                <div class="fw-bold fs-4">
                                    <field name="name"/>
                                </div>
                            </div>
                            <div class="text-muted text-truncate" style="max-height: 50px;">
                                <field name="descripcion"/>
                            </div>
                            <div class="mt-auto pt-2 border-top text-end">
                                <span class="badge rounded-pill bg-info text-dark">Ver detalles</span>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>


    <record id="action_carbon_track_alcance" model="ir.actions.act_window">
        <field name="name">Alcances</field>
        <field name="res_model">carbon.track.alcance</field>
        <field name="view_mode">kanban,list,form</field>
    </record>

    <record id="action_carbon_track_periodo" model="ir.actions.act_window">
        <field name="name">Periodos</field>
        <field name="res_model">carbon.track.periodo</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="action_carbon_track_emision" model="ir.actions.act_window">
        <field name="name">Factores de Emisión</field>
        <field name="res_model">carbon.track.emision</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="action_carbon_track_actividad" model="ir.actions.act_window">
        <field name="name">Actividades</field>
        <field name="res_model">carbon.track.actividad</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="action_carbon_track_reporte" model="ir.actions.act_window">
        <field name="name">Informes de Huella de Carbono</field>
        <field name="res_model">carbon.track.reporte</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Genera tu primer informe de emisiones.
            </p>
            <p>
                Selecciona un periodo fiscal para consolidar todos los registros generados y dividirlos por su alcance normativo.
            </p>
        </field>
    </record>

    <record id="action_carbon_track_fuente_externa" model="ir.actions.act_window">
        <field name="name">Fuentes Externas API</field>
        <field name="res_model">carbon.track.fuente.externa</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="action_carbon_track_registro" model="ir.actions.act_window">
        <field name="name">Registros de Consumo</field>
        <field name="res_model">carbon.track.registro</field>
        <field name="view_mode">list,form,graph</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
            Crea tu primer registro de consumo para empezar a medir la huella.
            </p>
        </field>
    </record>

    <record id="action_carbon_track_compensacion" model="ir.actions.act_window">
        <field name="name">Compensaciones</field>
        <field name="res_model">carbon.track.compensacion</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- Lista de los registros-->
    <record id="view_carbon_track_registro_list" model="ir.ui.view">
        <field name="name">carbon.track.registro.list</field>
        <field name="model">carbon.track.registro</field>
        <field name="arch" type="xml">
            <list string="Registros de Consumo" decoration-info="valor_co2e &gt; 0">
                <field name="fecha"/>
                <field name="actividad_id"/>
                <field name="periodo_id"/>
                <field name="cantidad"/>
                <field name="unidad"/>
                <field name="valor_co2e" sum="Total CO2e Generado"/>
                <field name="nivel_impacto" 
                       widget="badge" 
                       decoration-success="nivel_impacto == 'bajo'" 
                       decoration-warning="nivel_impacto == 'medio'" 
                       decoration-danger="nivel_impacto == 'alto'"/>
            </list>
        </field>
    </record>

    

    <!-- Graficos de los registros-->
    <record id="view_carbon_track_registro_graph" model="ir.ui.view">
        <field name="name">carbon.track.registro.graph</field>
        <field name="model">carbon.track.registro</field>
        <field name="arch" type="xml">
            <graph string="Análisis de Emisiones" type="bar" sample="1">
                <field name="actividad_id"/> 
                <field name="valor_co2e" type="measure"/>
            </graph>
        </field>
    </record>


    <!-- Formulario de los registros-->
    <record id="view_carbon_track_registro_form" model="ir.ui.view">
    <field name="name">carbon.track.registro.form</field>
    <field name="model">carbon.track.registro</field>
    <field name="arch" type="xml">
        <form string="Registro de Emisión">
            <sheet>
                <div class="oe_button_box" name="button_box">
                    <button name="action_view_caes" type="object" class="oe_stat_button" icon="fa-bolt">
                        <div class="o_stat_info">
                            <field name="cae_count" class="o_stat_value"/>
                            <span class="o_stat_text">Certificados CAE</span>
                        </div>
                    </button>
                </div>
                <div class="oe_title">
                    <h1>
                        <field name="name" readonly="1"/>
                    </h1>
                </div>
                <group>
                    <group string="Información Principal">
                        <field name="concepto"/>
                        <field name="periodo_id" options="{'no_create': True}"/>
                        <field name="actividad_id" options="{'no_create': True}"/>
                        <field name="fecha"/>
                    </group>
                    <group string="Cálculo de Consumo">
                        <label for="cantidad" string="Consumo Reportado"/>
                        <div class="o_row">
                            <field name="cantidad" class="oe_inline"/>
                            <field name="unidad" class="oe_inline fw-bold" readonly="1" force_save="1"/>
                        </div>
    
                        <field name="valor_co2e" class="fw-bold" decoration-danger="valor_co2e > 100" readonly="1"/>
                    </group>    
                </group>
                <notebook>
                    <page string="Notas y Auditoría">
                        <field name="notas" placeholder="Añade aquí detalles sobre la factura o el ticket..."/>
                    </page>
                </notebook>
            </sheet>
        </form>
    </field>
</record>

    <!-- el formulario de las actividades-->
    <record id="view_carbon_track_actividad_form" model="ir.ui.view">
        <field name="name">carbon.track.actividad.form</field>
        <field name="model">carbon.track.actividad</field>
        <field name="arch" type="xml">
            <form string="Actividad Emisora">
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_registros" 
                                type="object" 
                                class="oe_stat_button" 
                                icon="fa-leaf">
                            <div class="o_stat_info">
                                <span class="o_stat_value">
                                    <field name="registro_count"/> Usos
                                </span>
                                <span class="o_stat_text text-danger fw-bold">
                                    <field name="total_co2e_acumulado" widget="float" digits="[16,2]"/> kg CO2
                                </span>
                            </div>
                        </button>
                    </div>

                    <widget name="web_ribbon" title="Archivada" bg_color="bg-danger" invisible="activo"/>

                    <div class="oe_title">
                        <label for="name" string="Nombre de la Actividad"/>
                        <h1>
                            <field name="name" placeholder="Ej. Consumo Eléctrico Oficinas"/>
                        </h1>
                        <h2>
                            <field name="codigo" class="text-muted"/>
                        </h2>
                    </div>

                    <group>
                        <group string="Clasificación Normativa" name="clasificacion">
                            <field name="alcance_id" options="{'no_create': True}" widget="selection_badge"/>
                        </group>
                        
                        <group string="Parámetros de Cálculo" name="calculo">
                            <field name="factor_emision_id" options="{'no_create': True, 'no_open': False}"/>
                            <label for="unidad" string="Unidad de Medida"/>
                            <div class="o_row">
                                <field name="unidad" readonly="1" force_save="1" class="oe_inline fw-bold text-primary"/>
                            </div>
                            <field name="activo" widget="boolean_toggle" string="En uso"/>
                        </group>
                    </group>

                    <notebook>
                        <page string="Descripción / Notas" name="notas">
                            <field name="description" placeholder="Detalla aquí la justificación de esta actividad o metodología..."/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    
    <!-- el formulario de los alcances-->
    <record id="view_carbon_track_alcance_form" model="ir.ui.view">
        <field name="name">carbon.track.alcance.form</field>
        <field name="model">carbon.track.alcance</field>
        <field name="arch" type="xml">
            <form string="Ficha de Alcance">
                <sheet>
                    <field name="imagen" widget="image" class="oe_avatar" options='{"preview_image": "imagen"}'/>
                    
                    <div class="oe_title">
                        <label for="name" string="Tipo de Alcance"/>
                        <h1><field name="name" readonly="1"/></h1>
                    </div>

                    <group>
                        <group string="Información Didáctica">
                            <field name="descripcion" placeholder="Explica aquí qué incluye este alcance..."/>
                        </group>
                        <group string="Recursos de Apoyo">
                            <label for="enlace_guia"/>
                            <div class="o_row">
                                <field name="enlace_guia" widget="url" placeholder="https://www.miteco.gob.es/..."/>
                            </div>
                            
                            <field name="documento_apoyo" filename="documento_nombre"/>
                            <field name="documento_nombre" invisible="1"/>
                        </group>
                    </group>
                    
                    <div class="alert alert-warning" role="alert" style="margin-top: 20px;" invisible="not enlace_guia">
                        <i class="fa fa-external-link"></i> 
                        <strong>Nota para el usuario:</strong> Para una comprensión profunda, consulte la documentación oficial en el enlace superior.
                    </div>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Lista de los periodos-->
    <record id="view_carbon_track_periodo_list" model="ir.ui.view">
        <field name="name">carbon.track.periodo.list</field>
        <field name="model">carbon.track.periodo</field>
        <field name="arch" type="xml">
            <list string="Periodos">
                <field name="name"/>
                <field name="fecha_inicio"/>
                <field name="fecha_fin"/>
                <field name="presupuesto_co2e"/>
                <field name="total_co2e_consumido"/>
                <field name="porcentaje_consumido" widget="progressbar"/>
            </list>
        </field>
    </record>


    <!--Formulario de los periodos-->
    <record id="view_carbon_track_periodo_form" model="ir.ui.view">
        <field name="name">carbon.track.periodo.form</field>
        <field name="model">carbon.track.periodo</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_send_email" 
                            string="Enviar Informe por Email" 
                            type="object" 
                            class="oe_highlight" 
                            icon="fa-envelope"/>

                    <button name="action_abrir" 
                            string="Abrir Periodo" 
                            type="object" 
                            class="oe_highlight" 
                            invisible="estado != 'borrador'"/>
                    
                    <button name="action_cerrar" 
                            string="Cerrar Periodo" 
                            type="object" 
                            class="oe_highlight" 
                            invisible="estado != 'abierto'"/>
                    
                    <button name="action_borrador" 
                            string="Volver a Borrador" 
                            type="object" 
                            invisible="estado == 'borrador'"/>
                    
                    <field name="estado" widget="statusbar" statusbar_visible="borrador,abierto,cerrado"/>
                </header>
                <sheet>
                    <widget name="web_ribbon" title="¡NET ZERO!" bg_color="text-bg-success" invisible="not es_net_zero"/>
                    <div class="oe_title">
                        <h1><field name="name" placeholder="Ej. Mayo 2026"/></h1>
                    </div>
                    <group>
                        <group string="Fechas del Periodo">
                            <field name="fecha_inicio"/>
                            <field name="fecha_fin"/>
                        </group>
                        <group string="Balance Ecológico">
                            <field name="total_co2e_consumido" decoration-danger="1"/>
                            <field name="total_co2e_compensado" decoration-success="1"/>
                            <field name="huella_neta" class="fw-bold fs-5"/>
                        </group>
                        <group string="Control de Presupuesto">
                            <field name="presupuesto_co2e"/>
                            <field name="porcentaje_consumido" widget="progressbar"/>
                            <field name="es_net_zero" invisible="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Proyectos de Compensación">
                            <field name="compensacion_ids">
                                <list editable="bottom">
                                    <field name="fecha"/>
                                    <field name="name"/>
                                    <field name="tipo"/>
                                    <field name="co2e_compensado" sum="Total"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_carbon_track_compensacion_form" model="ir.ui.view">
    <field name="name">carbon.track.compensacion.form</field>
    <field name="model">carbon.track.compensacion</field>
    <field name="arch" type="xml">
        <form string="Proyecto de Compensación">
            <sheet>
                <div class="oe_title">
                    <span class="text-muted" invisible="codigo == 'Nuevo'">Referencia: </span>
                    <h1>
                        <field name="codigo" class="text-primary"/>
                    </h1>
                    <label for="name" string="Nombre del Proyecto"/>
                    <h2>
                        <field name="name" placeholder="Ej. Reforestación Sierra de Gredos"/>
                    </h2>
                </div>

                <group>
                    <group string="Detalles de la Acción" name="main_details">
                        <field name="tipo" widget="priority" invisible="1"/> <field name="tipo" widget="selection_badge" options="{'horizontal': true}"/>
                        <field name="fecha"/>
                        <field name="periodo_id" options="{'no_create': True, 'no_open': False}"/>
                    </group>

                    <group string="Impacto Positivo" name="impact">
                        <label for="co2e_compensado"/>
                        <div class="o_row">
                            <field name="co2e_compensado" class="oe_inline fw-bold" style="font-size: 1.2em; color: #28a745;"/>
                            <span class="fw-bold">kg CO2e</span>
                        </div>
                        <div class="alert alert-info mt-2" role="alert" style="padding: 5px 10px;">
                            <i class="fa fa-info-circle"/> Este valor se restará de la huella neta del periodo.
                        </div>
                    </group>
                </group>

                <notebook>
                    <page string="Documentación y Certificados" name="docs">
                        <group>
                            <field name="notas" widget="html" placeholder="Pega aquí el enlace al certificado oficial o detalles del proyecto..."/>
                        </group>
                    </page>
                    <page string="Auditoría" name="audit">
                        <group>
                            <field name="create_uid" readonly="1" string="Registrado por"/>
                            <field name="create_date" readonly="1" string="Fecha de registro"/>
                        </group>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>    
    </record>

    <!--Formulario de la fuente externa-->
    <record id="view_carbon_track_fuente_externa_form" model="ir.ui.view">
        <field name="name">carbon.track.fuente.externa.form</field>
        <field name="model">carbon.track.fuente.externa</field> <field name="arch" type="xml">
            <form string="Fuente de Datos">
                <header>
                    <button name="action_test_connection" 
                            type="object" 
                            string="Probar Conexión" 
                            icon="fa-plug"
                            invisible="not api_key"/> <button name="action_sync_factors" 
                            type="object" 
                            string="Sincronizar Catálogo" 
                            class="oe_highlight" 
                            icon="fa-cloud-download"
                            invisible="not anio_filtro or not pais_filtro or cantidad_limite &lt;= 0"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="Ej: Climatiq API"/>
                        </h1>
                    </div>
                    <group>
                        <group string="Credenciales" name="api_config">
                            <field name="api_key" password="True"/> 
                        </group>
                        
                        <group string="Parámetros de Búsqueda" name="api_filtros">
                            <field name="anio_filtro" placeholder="Ej. 2024"/>
                            <field name="pais_filtro" placeholder="Ej. ES"/>
                            <field name="cantidad_limite"/>
                        </group>
                    </group>
                    
                    <div class="alert alert-warning" role="alert" invisible="anio_filtro and pais_filtro and cantidad_limite &gt; 0">
                        <i class="fa fa-exclamation-triangle"/> 
                        Debes rellenar el Año, el País y la Cantidad para que aparezca el botón de Sincronizar.
                    </div>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_carbon_track_emision_form" model="ir.ui.view">
        <field name="name">carbon.track.emision.form</field>
        <field name="model">carbon.track.emision</field>
        <field name="arch" type="xml">
            <form string="Factor de Emisión">
                <sheet>
                    <widget name="web_ribbon" title="Oficial" bg_color="bg-info" invisible="not es_oficial"/>

                    <div class="oe_title">
                        <label for="name" string="Nombre del Factor"/>
                        <h1>
                            <field name="name" placeholder="Ej: Electricidad - Mix 2024"/>
                        </h1>
                    </div>

                    <group>
                        <group string="Origen y Clasificación">
                            <field name="fuente_origen"/>
                            <field name="region"/>
                            <field name="anio"/>
                            <field name="categoria"/>
                            <field name="fuente_externa_id" options="{'no_create': True}"/>
                        </group>

                        <group string="Datos de Cálculo">
                            <label for="valor"/>
                            <div class="o_row">
                                <field name="valor" class="oe_inline fw-bold"/>
                                <field name="unidad" class="oe_inline" placeholder="Unidad"/>
                            </div>
                            <field name="es_oficial" widget="boolean_toggle"/>
                        </group>
                    </group>

                    <notebook>
                        <page string="Validez y Bibliografía" name="validez">
                            <group>
                                <group string="Periodo de Validez">
                                    <field name="valido_desde"/>
                                    <field name="valido_hasta"/>
                                </group>
                                <group string="Referencias">
                                    <field name="fuentes" placeholder="Enlaces o referencias bibliográficas..."/>
                                </group>
                            </group>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_carbon_track_emision_list" model="ir.ui.view">
        <field name="name">carbon.track.emision.list</field>
        <field name="model">carbon.track.emision</field>
        <field name="arch" type="xml">
            <list string="Factores de Emisión" decoration-info="es_oficial == True">
                <field name="name"/>
                <field name="categoria" optional="show"/>
                <field name="region"/>
                <field name="anio"/>
                <field name="valor" sum="Total"/>
                <field name="unidad"/>
                <field name="fuente_origen" optional="hide"/>
                <field name="es_oficial" widget="boolean_toggle" optional="show"/>
            </list>
        </field>
    </record>

    <record id="view_carbon_track_emision_search" model="ir.ui.view">
        <field name="name">carbon.track.emision.search</field>
        <field name="model">carbon.track.emision</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="categoria"/>
                <field name="region"/>
                <field name="fuente_origen"/>
                
                <filter string="Oficiales" name="official" domain="[('es_oficial', '=', True)]"/>
                <filter string="Manuales" name="manual" domain="[('es_oficial', '=', False)]"/>
                <separator/>
                <filter string="Vigentes" name="current" domain="[('valido_hasta', '>=', context_today())]"/>

                <group expand="0" string="Agrupar por...">
                    <filter string="Categoría" name="group_categoria" context="{'group_by':'categoria'}"/>
                    <filter string="Región" name="group_region" context="{'group_by':'region'}"/>
                    <filter string="Año" name="group_anio" context="{'group_by':'anio'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="view_carbon_track_reporte_form" model="ir.ui.view">
        <field name="name">carbon.track.reporte.form</field>
        <field name="model">carbon.track.reporte</field>
        <field name="arch" type="xml">
            <form string="Informe de Emisiones">
                <sheet>
                    <div class="oe_title">
                        <label for="name" string="Nombre del Informe"/>
                        <h1>
                            <field name="name" placeholder="Selecciona un periodo para generar..."/>
                        </h1>
                    </div>

                    <group>
                        <group string="Datos del Informe" name="datos_principales">
                            <field name="periodo_id" options="{'no_create': True, 'no_open': False}"/>
                            <field name="fecha_de_generacion" readonly="1"/>
                        </group>
                        
                        <group string="Desglose por Alcances" name="totales_alcance">
                            <label for="total_alcance1" string="Alcance 1 (Directas)"/>
                            <div class="o_row">
                                <field name="total_alcance1" readonly="1" class="oe_inline fw-bold text-danger"/>
                                <span class="text-muted">kg CO2e</span>
                            </div>
                            
                            <label for="total_alcance2" string="Alcance 2 (Indirectas Energía)"/>
