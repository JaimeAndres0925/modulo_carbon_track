<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_hr_expense_form_inherit_carbon" model="ir.ui.view">
        <field name="name">hr.expense.form.inherit.carbon</field>
        <field name="model">hr.expense</field>
        <field name="inherit_id" ref="hr_expense.hr_expense_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='product_id']" position="after">
                <field name="es_gasto_contaminante"/>
                <field name="carbon_actividad_id" invisible="not es_gasto_contaminante"/>
            </xpath>
        </field>
    </record>
</odoo>