<odoo>
    <record id="view_move_form_inherit_carbon" model="ir.ui.view">
        <field name="name">account.move.form.inherit.carbon</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">
            <xpath expr="//header" position="inside">
                <button name="action_create_cae" 
                        string="Generar CAE" 
                        type="object" 
                        class="btn-primary" 
                        invisible="move_type != 'in_invoice' or state != 'posted'"/>
            </xpath>
        </field>
    </record>
</odoo>