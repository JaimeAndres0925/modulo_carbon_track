<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="report_huella_template">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="o">
                <t t-call="web.external_layout">
                    
                    <style>
                        .carbon-header {
                            background-color: #0a1128;
                            padding: 20px;
                            border-radius: 5px;
                            border-bottom: 3px solid #00f0ff;
                            margin-bottom: 20px;
                        }
                        .kpi-card {
                            background-color: #f8f9fa;
                            border: 1px solid #dee2e6;
                            padding: 10px;
                            border-radius: 5px;
                            margin-bottom: 15px;
                        }
                        .net-zero-banner {
                            background-color: #d4edda;
                            color: #155724;
                            text-align: center;
                            padding: 10px;
                            font-weight: bold;
                            border-radius: 5px;
                            margin-bottom: 20px;
                            border: 1px solid #c3e6cb;
                        }
                        .custom-table th {
                            background-color: #0a1128;
                            color: #ffffff;
                        }
                    </style>

                    <div class="page">
                        
                        <div class="carbon-header text-center">
                            <h2 style="margin:0; color: #ffffff;">Informe Huella de Carbono</h2>
                            <h4 style="margin-top:5px; color: #00f0ff;"><t t-out="o.periodo_id.name"/></h4>
                        </div>

                        <t t-if="o.periodo_id.es_net_zero">
                            <div class="net-zero-banner">
                                ¡Objetivo Net Zero Alcanzado!
                            </div>
                        </t>

                        <div class="row text-center mt-3">
                            <div class="col-4">
                                <div class="kpi-card">
                                    <div class="text-muted" style="font-size: 13px;">Total Generado</div>
                                    <h4 style="margin: 5px 0 0 0;"><t t-out="o.periodo_id.total_co2e_consumido"/> kg</h4>
                                </div>
                            </div>
                            <div class="col-4">
                                <div class="kpi-card">
                                    <div class="text-muted" style="font-size: 13px;">Total Compensado</div>
                                    <h4 style="margin: 5px 0 0 0;"><t t-out="o.periodo_id.total_co2e_compensado"/> kg</h4>
                                </div>
                            </div>
                            <div class="col-4">
                                <div class="kpi-card" style="background-color: #e9ecef;">
                                    <div class="text-muted" style="font-size: 13px;">Huella Neta Final</div>
                                    <h4 style="margin: 5px 0 0 0; font-weight: bold;"><t t-out="o.periodo_id.huella_neta"/> kg</h4>
                                </div>
                            </div>
                        </div>

                        <div class="mb-4 mt-2">
                            <span style="font-size: 14px;">
                                <strong>Presupuesto consumido:</strong> <t t-out="round(o.periodo_id.porcentaje_consumido, 1)"/>% de <t t-out="o.periodo_id.presupuesto_co2e"/> kg
                            </span>
                            <div class="progress mt-1" style="height: 12px;">
                                <div t-attf-class="progress-bar #{'bg-danger' if o.periodo_id.porcentaje_consumido &gt; 100 else 'bg-info'}" 
                                     role="progressbar" 
                                     t-attf-style="width: #{o.periodo_id.porcentaje_consumido if o.periodo_id.porcentaje_consumido &lt; 100 else 100}%; background-color: #00f0ff;"/>
                            </div>
                        </div>

                        <table class="table table-sm custom-table mt-4">
                            <thead>
                                <tr>
                                    <th>Concepto</th>
                                    <th class="text-right">Emisiones (kg CO2e)</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr>
                                    <td>Alcance 1 (Emisiones Directas)</td>
                                    <td class="text-right"><t t-out="o.total_alcance1"/></td>
                                </tr>
                                <tr>
                                    <td>Alcance 2 (Energía)</td>
                                    <td class="text-right"><t t-out="o.total_alcance2"/></td>
                                </tr>
                                <tr>
                                    <td>Alcance 3 (Indirectas)</td>
                                    <td class="text-right"><t t-out="o.total_alcance3"/></td>
                                </tr>
                            </tbody>
                        </table>
                        
                    </div>
                </t>
            </t>
        </t>
    </template>
</odoo>