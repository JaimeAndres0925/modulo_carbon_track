<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="report_huella_template">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="o">
                <t t-call="web.external_layout">
                    <div class="page">
                        <h2 class="text-center">Informe de Huella de Carbono</h2>
                        <h3 class="text-center"><t t-out="o.periodo_id.name"/></h3>
                        <br/>
                        <table class="table table-sm">
                            <thead>
                                <tr>
                                    <th>Concepto</th>
                                    <th class="text-right">Emisiones (kg CO2e)</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr>
                                    <td>Alcance 1 (Emisiones Directas)</td>
                                    <td class="text-right"><t t-out="o.total_alcance1"/></td>
                                </tr>
                                <tr>
                                    <td>Alcance 2 (Energía)</td>
                                    <td class="text-right"><t t-out="o.total_alcance2"/></td>
                                </tr>
                                <tr>
                                    <td>Alcance 3 (Indirectas)</td>
                                    <td class="text-right"><t t-out="o.total_alcance3"/></td>
                                </tr>
                            </tbody>
                        </table>
                        <div class="text-right mt-4">
                            <strong>Total Huella: <t t-out="o.total_alcance1 + o.total_alcance2 + o.total_alcance3"/> kg CO2e</strong>
                        </div>
                    </div>
                </t>
            </t>
        </t>
    </template>
</odoo>